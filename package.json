{
  "name": "quay",
  "version": "0.1.1",
  "description": "A terminal multiplexer built for multi-repo workflows",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "npm run build:electron && concurrently -k \"vite\" \"wait-on tcp:5173 && NODE_ENV=development electron .\"",
    "build:electron": "tsup electron/main.ts electron/preload.ts --outDir dist-electron --format cjs --external electron --external node-pty && node -e \"require('fs').copyFileSync('electron/quay-hook.sh','dist-electron/quay-hook.sh');require('fs').copyFileSync('build/icons/icons/png/512x512.png','dist-electron/icon.png')\"",
    "build:renderer": "vite build",
    "build": "npm run build:electron && npm run build:renderer",
    "pack": "npm run build && electron-builder",
    "pack:win": "npm run build && electron-builder --win",
    "pack:mac": "npm run build && electron-builder --mac",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run typecheck && npm run lint && npm run format:check && npm run test",
    "postinstall": "npx @electron/rebuild && node -e \"if(process.platform==='darwin'){const p=require('path').join('node_modules/electron/dist/Electron.app/Contents/Info.plist');require('child_process').execSync('plutil -replace CFBundleName -string Quay '+p+' && plutil -replace CFBundleDisplayName -string Quay '+p)}\"",
    "prepare": "husky"
  },
  "build": {
    "appId": "com.quay.app",
    "productName": "Quay",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "mac": {
      "icon": "build/icons/icons/mac/icon.icns",
      "target": [
        "dmg"
      ]
    },
    "win": {
      "icon": "build/icons/icons/win/icon.ico",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false
    },
    "portable": {
      "artifactName": "Quay-${version}-portable.exe"
    }
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/space-grotesk": "^5.2.10",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.18.0",
    "@xterm/xterm": "^5.5.0",
    "node-pty": "^1.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@electron/rebuild": "^3.7.0",
    "@eslint/js": "^10.0.1",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "prettier": "^3.8.1",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.57.0",
    "vite": "^6.0.0",
    "vitest": "^4.0.18",
    "wait-on": "^8.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,yml,yaml,mjs}": [
      "prettier --write"
    ]
  }
}
